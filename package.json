{
  "name": "ai-seo-saas",
  "private": true,
  "version": "1.0.0",
  "description": "Autonomous AI SEO SaaS: multi-tenant agents, API, worker, and dashboard.",
  "main": "app.js",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "start": "node app.js",
    "dev": "node app.js",
    "api": "node apps/api/index.js",
    "worker": "node apps/worker/index.js",
    "prisma:migrate": "cd packages/database && npx prisma migrate dev",
    "prisma:generate": "cd packages/database && npx prisma generate",
    "lint": "echo \"Add linter\"",
    "test": "echo \"No tests yet\""
  },
  "keywords": [
    "seo",
    "ai",
    "wordpress",
    "automation",
    "cron",
    "google-trends"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@prisma/client": "^5.11.0",
    "axios": "^1.13.6",
    "bcryptjs": "^2.4.3",
    "body-parser": "^1.20.2",
    "bullmq": "^5.5.3",
    "cheerio": "^1.2.0",
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "express": "^4.19.2",
    "google-trends-api": "^4.9.2",
    "googleapis": "^171.4.0",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.2",
    "marked": "^17.0.4",
    "node-cron": "^4.2.1",
    "openai": "^6.25.0",
    "prisma": "^5.11.0",
    "slugify": "^1.6.6"
  }
}
